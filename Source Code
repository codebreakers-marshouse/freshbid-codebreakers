// BUYER: AUCTION ROOM (live simulation)
// ─────────────────────────────────────────────────────────────

function AuctionRoom({ params, navigate, toast }) {
  const [lot, setLot]         = useState({ ...params.lot });
  const [bidAmount, setBid]   = useState(String((params.lot.currentPrice + 5).toFixed(2)));
  const [charity, setCharity] = useState(CHARITIES[0].id);
  const [msLeft, setMsLeft]   = useState(params.lot.auctionEnd - Date.now());
  const [placing, setPlacing] = useState(false);
  const [antiSnipe, setAntiSnipe] = useState(lot.status === "anti_snipe");
  const [bidStream, setBidStream] = useState(lot.bids || []);

  // Countdown
  useEffect(() => {
    const id = setInterval(() => {
      const left = lot.auctionEnd - Date.now();
      setMsLeft(Math.max(0, left));
    }, 1000);
    return () => clearInterval(id);
  }, [lot.auctionEnd]);

  // Simulate live bids from other buyers every 12-25 seconds
  useEffect(() => {
    const names = ["K***", "S***", "R***", "N***", "Z***", "A***", "M***"];
    const simulate = () => {
      const randomBuyer = names[Math.floor(Math.random() * names.length)];
      const newAmount = lot.currentPrice + Math.floor(Math.random() * 8 + 2);
      const newBid = { buyer: randomBuyer, amount: newAmount, at: "just now" };
      setLot(prev => ({ ...prev, currentPrice: newAmount, bidCount: prev.bidCount + 1 }));
      setBidStream(prev => [newBid, ...prev.slice(0, 8)]);
      setBid(String((newAmount + 5).toFixed(2)));
      toast(`${randomBuyer} just bid ${fmtCurrency(newAmount)}`, "warn");
    };
    const delay = 12000 + Math.random() * 13000;
    const id = setTimeout(simulate, delay);
    return () => clearTimeout(id);
  }, [lot.currentPrice]);

  const minBid  = lot.currentPrice + 1;
  const amount  = parseFloat(bidAmount) || 0;
  const donation = amount * 0.15;
  const charityName = CHARITIES.find(c => c.id === charity)?.name;

  const placeBid = () => {
    if (amount < minBid) { toast(`Minimum bid is ${fmtCurrency(minBid)}`, "error"); return; }
    setPlacing(true);
    setTimeout(() => {
      const wasUrgent = msLeft < 120_000;
      if (wasUrgent && !antiSnipe) {
        setAntiSnipe(true);
        setLot(prev => ({ ...prev, auctionEnd: prev.auctionEnd + 120_000, status: "anti_snipe" }));
        toast("⚡ Anti-snipe triggered — auction extended 2 minutes!");
      }
      const myBid = { buyer: "You", amount, at: "just now" };
      setLot(prev => ({ ...prev, currentPrice: amount, bidCount: prev.bidCount + 1 }));
      setBidStream(prev => [myBid, ...prev.slice(0, 8)]);
      setBid(String((amount + 5).toFixed(2)));
      setPlacing(false);
      toast(`Bid of ${fmtCurrency(amount)} placed! Funds held by Stripe.`);
    }, 900);
  };

  const buyNow = () => {
    toast(`Lot purchased for ${fmtCurrency(lot.buyNow)}! Pickup details sent.`);
    setTimeout(() => navigate("my-wins"), 2000);
  };

  const isActive = msLeft > 0;

  return (
    <div style={{ padding: 28, maxWidth: 960, margin: "0 auto" }}>
      <button onClick={() => navigate("browse")} style={{ background: "none", border: "none", color: "#0F4C2A", cursor: "pointer", fontWeight: 600, fontSize: 14, marginBottom: 16 }}>
        ← Back to auctions
      </button>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 340px", gap: 20 }}>

        {/* Left: lot details */}
        <div>
          <Card style={{ marginBottom: 16 }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 16 }}>
              <div>
                <h1 style={{ fontSize: 22, fontWeight: 800, color: "#111827", margin: "0 0 4px" }}>{lot.title}</h1>
                <p style={{ color: "#9CA3AF", fontSize: 14, margin: 0 }}>{lot.supplier} · {lot.zone}</p>
              </div>
              {antiSnipe
                ? <Badge color="#92400E" bg="#FEF3C7">⚡ Extended</Badge>
                : isActive
                  ? <Badge color="#065F46" bg="#D1FAE5">🟢 Live</Badge>
                  : <Badge color="#374151" bg="#F3F4F6">Closed</Badge>
              }
            </div>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 16 }}>
              {[
                ["Quantity",    `${lot.quantity} ${lot.unit}`],
                ["Temperature", `${TEMP_ICON[lot.temperature]} ${lot.temperature}`],
                ["Pickup from", fmtTime(lot.pickupStart)],
                ["Pickup until",fmtTime(lot.pickupEnd)],
                ["Allergens",   lot.allergens.length ? lot.allergens.join(", ") : "None listed"],
                ["Zone",        lot.zone],
              ].map(([k, v]) => (
                <div key={k} style={{ background: "#F9FAFB", borderRadius: 8, padding: "10px 12px" }}>
                  <p style={{ fontSize: 11, color: "#9CA3AF", margin: "0 0 3px", fontWeight: 600, textTransform: "uppercase" }}>{k}</p>
                  <p style={{ fontSize: 14, color: "#111827", margin: 0, fontWeight: 500, textTransform: "capitalize" }}>{v}</p>
                </div>
              ))}
            </div>

            {lot.description && <p style={{ fontSize: 14, color: "#6B7280", lineHeight: 1.6, margin: 0 }}>{lot.description}</p>}
          </Card>

          {/* Bid stream */}
          <Card>
            <h3 style={{ fontSize: 15, fontWeight: 700, color: "#111827", marginTop: 0, marginBottom: 14 }}>Live bid activity</h3>
            {bidStream.length === 0
              ? <p style={{ color: "#9CA3AF", fontSize: 14 }}>No bids yet. Be the first!</p>
              : bidStream.map((b, i) => (
                  <div key={i} style={{
                    display: "flex", justifyContent: "space-between", alignItems: "center",
                    padding: "8px 0", borderBottom: i < bidStream.length - 1 ? "1px solid #F3F4F6" : "none",
                  }}>
                    <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                      <div style={{
                        width: 30, height: 30, borderRadius: "50%",
                        background: b.buyer === "You" ? "#0F4C2A" : "#E5E7EB",
                        display: "flex", alignItems: "center", justifyContent: "center",
                        fontSize: 13, fontWeight: 700,
                        color: b.buyer === "You" ? "#fff" : "#374151",
                      }}>
                        {b.buyer[0]}
                      </div>
                      <span style={{ fontSize: 14, color: "#374151" }}>
                        {b.buyer === "You" ? <strong>You</strong> : b.buyer}
                      </span>
                    </div>
                    <div style={{ textAlign: "right" }}>
                      <p style={{ fontSize: 16, fontWeight: 700, color: "#0F4C2A", margin: "0 0 1px" }}>{fmtCurrency(b.amount)}</p>
                      <p style={{ fontSize: 11, color: "#9CA3AF", margin: 0 }}>{b.at}</p>
                    </div>
                  </div>
                ))
            }
          </Card>
        </div>

        {/* Right: bidding panel */}
        <div>
          {/* Countdown */}
          <div style={{
            background: antiSnipe ? "#FFFBEB" : isActive ? "#F0FDF4" : "#F9FAFB",
            border: `2px solid ${antiSnipe ? "#F59E0B" : isActive ? "#86EFAC" : "#E5E7EB"}`,
            borderRadius: 12, padding: 16, textAlign: "center", marginBottom: 16,
          }}>
            <p style={{ fontSize: 11, fontWeight: 600, color: "#9CA3AF", textTransform: "uppercase", margin: "0 0 6px" }}>
              {antiSnipe ? "Extended — time remaining" : "Time remaining"}
            </p>
            <p style={{
              fontSize: 40, fontWeight: 900, fontFamily: "monospace", margin: "0 0 4px",
              color: antiSnipe ? "#D97706" : msLeft < 120_000 ? "#EF4444" : "#0F4C2A",
            }}>
              {fmtCountdown(msLeft)}
            </p>
            {antiSnipe && <p style={{ fontSize: 12, color: "#D97706", margin: 0 }}>⚡ Auction extended due to last-minute bid</p>}
          </div>

          {/* Current price */}
          <Card style={{ marginBottom: 16, textAlign: "center" }}>
            <p style={{ fontSize: 11, color: "#9CA3AF", textTransform: "uppercase", fontWeight: 600, margin: "0 0 6px" }}>Current price</p>
            <p style={{ fontSize: 36, fontWeight: 900, color: "#0F4C2A", margin: "0 0 4px" }}>{fmtCurrency(lot.currentPrice)}</p>
            <p style={{ fontSize: 12, color: "#9CA3AF", margin: 0 }}>{lot.bidCount} bid{lot.bidCount !== 1 ? "s" : ""} · reserve {fmtCurrency(lot.reservePrice)}</p>
          </Card>

          {isActive ? (
            <Card>
              {/* Bid amount */}
              <div style={{ marginBottom: 14 }}>
                <label style={{ display: "block", fontSize: 13, fontWeight: 600, color: "#374151", marginBottom: 6 }}>
                  Your bid (USD)
                </label>
                <input
                  type="number" value={bidAmount} min={minBid} step="0.5"
                  onChange={e => setBid(e.target.value)}
                  style={{
                    width: "100%", padding: "10px 12px", borderRadius: 8,
                    border: "2px solid #0F4C2A", fontSize: 22, fontWeight: 800,
                    color: "#0F4C2A", outline: "none", boxSizing: "border-box", textAlign: "center",
                  }}
                />
                <p style={{ fontSize: 12, color: "#9CA3AF", marginTop: 4 }}>
                  Minimum: {fmtCurrency(minBid)}
                </p>
              </div>

              {/* Charity */}
              <div style={{ marginBottom: 14 }}>
                <label style={{ display: "block", fontSize: 13, fontWeight: 600, color: "#374151", marginBottom: 6 }}>
                  Donate 15% to
                </label>
                <select value={charity} onChange={e => setCharity(e.target.value)}
                  style={{ width: "100%", padding: "8px 12px", borderRadius: 8, border: "1.5px solid #D1D5DB", fontSize: 14, background: "#fff", outline: "none" }}>
                  {CHARITIES.map(c => <option key={c.id} value={c.id}>{c.logo} {c.name}</option>)}
                </select>
              </div>

              {/* Donation preview */}
              {amount >= minBid && (
                <div style={{ background: "#F0FDF4", border: "1px solid #86EFAC", borderRadius: 8, padding: "10px 12px", marginBottom: 14 }}>
                  <p style={{ fontSize: 13, color: "#065F46", margin: 0 }}>
                    🤝 <strong>{fmtCurrency(donation)}</strong> will go to {charityName}
                  </p>
                  <p style={{ fontSize: 12, color: "#6B7280", margin: "2px 0 0" }}>
                    {fmtCurrency(amount * 0.77)} to supplier · {fmtCurrency(amount * 0.08)} platform fee
                  </p>
                </div>
              )}

              <Btn onClick={placeBid} disabled={placing || amount < minBid}
                style={{ width: "100%", padding: 12, fontSize: 16 }}>
                {placing ? "Placing bid…" : `Bid ${fmtCurrency(amount)}`}
              </Btn>

              {lot.buyNow && (
                <Btn onClick={buyNow} variant="ghost" style={{ width: "100%", padding: 10, marginTop: 8, fontSize: 14 }}>
                  Buy now for {fmtCurrency(lot.buyNow)}
                </Btn>
              )}

              <p style={{ fontSize: 11, color: "#9CA3AF", textAlign: "center", marginTop: 12 }}>
                Card is held, not charged until you win. Auto-released if outbid.
              </p>
            </Card>
          ) : (
            <Card style={{ textAlign: "center" }}>
              <p style={{ fontSize: 16, color: "#9CA3AF" }}>⛔ Auction has closed</p>
            </Card>
          )}
        </div>
      </div>
    </div>
  );
}

