function FraudQueue({ toast }) {
  const [events, setEvents]     = useState(FRAUD_EVENTS);
  const [resText, setResText]   = useState({});
  const [open, setOpen]         = useState(null);

  const SEV_COLOR = { 2: "#D97706", 3: "#EA580C", 4: "#DC2626", 5: "#7F1D1D" };
  const SEV_BG    = { 2: "#FEF3C7", 3: "#FED7AA", 4: "#FEE2E2", 5: "#FECACA" };
  const FLAG_LABEL = {
    fake_bid: "🎭 Fake bid", collusion: "🤝 Collusion",
    no_show: "👻 No-show",  price_manipulation: "💸 Price manipulation",
  };

  const resolve = (id) => {
    if (!resText[id]?.trim()) { toast("Enter a resolution note.", "error"); return; }
    setEvents(prev => prev.filter(e => e.id !== id));
    toast("Event resolved and logged.");
    setOpen(null);
  };

  return (
    <div style={{ padding: 28, maxWidth: 800, margin: "0 auto" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
        <h1 style={{ fontSize: 24, fontWeight: 800, color: "#0F4C2A", margin: 0 }}>Fraud Queue</h1>
        <Badge color={events.length > 0 ? "#991B1B" : "#065F46"} bg={events.length > 0 ? "#FEE2E2" : "#D1FAE5"}>
          {events.length} unreviewed
        </Badge>
      </div>

      {events.length === 0 ? (
        <Card style={{ textAlign: "center", padding: 48 }}>
          <p style={{ fontSize: 40, marginBottom: 8 }}>✅</p>
          <p style={{ fontWeight: 700, color: "#374151" }}>Queue clear. No events need review.</p>
        </Card>
      ) : (
        <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
          {events.map(ev => (
            <Card key={ev.id} style={{ borderLeft: `4px solid ${SEV_COLOR[ev.severity] || "#374151"}` }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
                <div style={{ flex: 1 }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 6 }}>
                    <span style={{
                      padding: "2px 10px", borderRadius: 99, fontSize: 12, fontWeight: 700,
                      background: SEV_BG[ev.severity] || "#F3F4F6",
                      color: SEV_COLOR[ev.severity] || "#374151",
                    }}>
                      Severity {ev.severity}
                    </span>
                    <span style={{ fontSize: 14, fontWeight: 600 }}>{FLAG_LABEL[ev.flagType] || ev.flagType}</span>
                  </div>
                  <p style={{ fontSize: 14, color: "#374151", margin: "0 0 6px", lineHeight: 1.5 }}>{ev.description}</p>
                  <p style={{ fontSize: 12, color: "#9CA3AF", margin: 0 }}>
                    {ev.displayName} · {ev.user} · {ev.role} · {timeAgo(ev.createdAt)}
                  </p>
                  <details style={{ marginTop: 8 }}>
                    <summary style={{ fontSize: 12, color: "#9CA3AF", cursor: "pointer" }}>View evidence</summary>
                    <pre style={{ fontSize: 12, background: "#F9FAFB", borderRadius: 6, padding: 8, marginTop: 6, overflow: "auto" }}>
                      {JSON.stringify(ev.evidence, null, 2)}
                    </pre>
                  </details>
                </div>
                <Btn onClick={() => setOpen(open === ev.id ? null : ev.id)} variant="secondary" style={{ marginLeft: 12, flexShrink: 0 }}>
                  {open === ev.id ? "Cancel" : "Resolve"}
                </Btn>
              </div>

              {open === ev.id && (
                <div style={{ marginTop: 12, paddingTop: 12, borderTop: "1px solid #F3F4F6", display: "flex", gap: 8 }}>
                  <input
                    value={resText[ev.id] || ""} onChange={e => setResText(p => ({ ...p, [ev.id]: e.target.value }))}
                    placeholder="Resolution note (required)…"
                    style={{ flex: 1, padding: "8px 12px", borderRadius: 8, border: "1.5px solid #D1D5DB", fontSize: 14, outline: "none" }}
                  />
                  <Btn onClick={() => resolve(ev.id)}>Save</Btn>
                </div>
              )}
            </Card>
          ))}
        </div>
      )}
    </div>
  );
}

