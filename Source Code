function Verifications({ toast }) {
  const [users, setUsers] = useState(PENDING_VERIFICATIONS);
  const STATUS_COLOR = {
    pending:      { color: "#92400E", bg: "#FEF3C7" },
    under_review: { color: "#1E40AF", bg: "#DBEAFE" },
  };

  const act = (id, action) => {
    setUsers(prev => prev.filter(u => u.id !== id));
    toast(`User ${action}d successfully.`);
  };

  return (
    <div style={{ padding: 28, maxWidth: 900, margin: "0 auto" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
        <h1 style={{ fontSize: 24, fontWeight: 800, color: "#0F4C2A", margin: 0 }}>Pending Verifications</h1>
        <Badge color="#92400E" bg="#FEF3C7">{users.length} pending</Badge>
      </div>

      {users.length === 0 ? (
        <Card style={{ textAlign: "center", padding: 48 }}>
          <p style={{ fontSize: 40, marginBottom: 8 }}>✅</p>
          <p style={{ fontWeight: 700, color: "#374151" }}>All caught up. No pending verifications.</p>
        </Card>
      ) : (
        <Card style={{ padding: 0, overflow: "hidden" }}>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 14 }}>
            <thead>
              <tr style={{ background: "#F9FAFB", borderBottom: "1px solid #E5E7EB" }}>
                {["Name & Email","Role","Status","Document","Submitted","Actions"].map(h => (
                  <th key={h} style={{ padding: "12px 16px", textAlign: "left", fontSize: 12, fontWeight: 700, color: "#6B7280", textTransform: "uppercase" }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {users.map((u, i) => {
                const sc = STATUS_COLOR[u.status] || STATUS_COLOR.pending;
                return (
                  <tr key={u.id} style={{ borderBottom: i < users.length - 1 ? "1px solid #F3F4F6" : "none" }}>
                    <td style={{ padding: "14px 16px" }}>
                      <p style={{ fontWeight: 600, margin: "0 0 2px" }}>{u.displayName}</p>
                      <p style={{ fontSize: 12, color: "#9CA3AF", margin: 0 }}>{u.email}</p>
                    </td>
                    <td style={{ padding: "14px 16px", textTransform: "capitalize" }}>{u.role}</td>
                    <td style={{ padding: "14px 16px" }}>
                      <Badge color={sc.color} bg={sc.bg}>{u.status.replace("_", " ")}</Badge>
                    </td>
                    <td style={{ padding: "14px 16px" }}>
                      <span style={{ fontSize: 12, color: "#2563EB", textDecoration: "underline", cursor: "pointer" }}>
                        {u.docType.replace("_", " ")} ↗
                      </span>
                    </td>
                    <td style={{ padding: "14px 16px", fontSize: 12, color: "#9CA3AF" }}>{timeAgo(u.createdAt)}</td>
                    <td style={{ padding: "14px 16px" }}>
                      <div style={{ display: "flex", gap: 8 }}>
                        <button onClick={() => act(u.id, "approve")} style={{
                          padding: "5px 12px", borderRadius: 6, border: "none", background: "#D1FAE5",
                          color: "#065F46", fontSize: 12, fontWeight: 700, cursor: "pointer",
                        }}>Approve</button>
                        <button onClick={() => act(u.id, "reject")} style={{
                          padding: "5px 12px", borderRadius: 6, border: "none", background: "#FEE2E2",
                          color: "#991B1B", fontSize: 12, fontWeight: 700, cursor: "pointer",
                        }}>Reject</button>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </Card>
      )}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
// MAIN APP
// ─────────────────────────────────────────────────────────────

export default function App() {
  const [user, setUser]       = useState(null);
  const [page, setPage]       = useState("login");
  const [params, setParams]   = useState({});
  const [toasts, setToasts]   = useState([]);

  const navigate = useCallback((to, p = {}) => {
    setPage(to);
    setParams(p);
  }, []);

  const toast = useCallback((msg, type = "success") => {
    const id = Date.now() + Math.random();
    setToasts(t => [...t, { id, msg, type }]);
    setTimeout(() => setToasts(t => t.filter(x => x.id !== id)), 4500);
  }, []);

  const login = (u) => {
    setUser(u);
    const defaultPage = { buyer: "browse", supplier: "supplier-dash", admin: "admin-dash" };
    setPage(defaultPage[u.role] || "browse");
    toast(`Welcome back, ${u.name.split(" ")[0]}!`);
  };

  const logout = () => {
    setUser(null);
    setPage("login");
    toast("Signed out.");
  };

  const renderPage = () => {
    switch (page) {
      case "login":         return <Login onLogin={login} />;
      case "browse":        return <BrowseLots navigate={navigate} toast={toast} />;
      case "auction-room":  return <AuctionRoom params={params} navigate={navigate} toast={toast} />;
      case "my-wins":       return <MyWins toast={toast} />;
      case "supplier-dash": return <SupplierDashboard navigate={navigate} />;
      case "add-inventory": return <AddInventory navigate={navigate} toast={toast} />;
      case "create-lot":    return <CreateLot navigate={navigate} toast={toast} />;
      case "admin-dash":    return <AdminDashboard navigate={navigate} />;
      case "fraud-queue":   return <FraudQueue toast={toast} />;
      case "verifications": return <Verifications toast={toast} />;
      default:              return <Login onLogin={login} />;
    }
  };

  return (
    <div style={{ fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", minHeight: "100vh", background: "#F8FAFC" }}>
      <style>{`
        * { box-sizing: border-box; }
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
        input:focus, select:focus { border-color: #0F4C2A !important; outline: none; }
        button:hover:not(:disabled) { opacity: 0.9; }
      `}</style>

      {user ? (
        <div style={{ display: "flex", minHeight: "100vh" }}>
          <Sidebar user={user} page={page} navigate={navigate} logout={logout} />
          <main style={{ flex: 1, overflowY: "auto", minHeight: "100vh" }}>
            {renderPage()}
          </main>
        </div>
      ) : renderPage()}

      <Toast toasts={toasts} />
    </div>
  );
}
