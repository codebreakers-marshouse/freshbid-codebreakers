function AddInventory({ navigate, toast }) {
  const [form, setForm] = useState({
    name: "", category: "bakery", quantity: "", unit: "kg",
    expiry: "", pickupStart: "", pickupEnd: "",
    temperature: "ambient", allergens: [],
  });
  const [prediction, setPrediction] = useState(null);
  const [loading, setLoading]       = useState(false);
  const [saved, setSaved]           = useState(false);

  const SURPLUS = { bakery: 0.30, produce: 0.20, dairy: 0.15, prepared: 0.25, meat: 0.10, dry: 0.05 };
  const PRICE   = { bakery: 3.2,  produce: 2.5,  dairy: 4.0,  prepared: 5.5, meat: 8.0,  dry: 2.0 };

  const predict = () => {
    if (!form.name || !form.quantity) { toast("Fill in name and quantity first", "error"); return; }
    setLoading(true);
    setTimeout(() => {
      const qty   = parseFloat(form.quantity) || 0;
      const pct   = SURPLUS[form.category] || 0.2;
      const surplusQty = qty * pct;
      const value = surplusQty * (PRICE[form.category] || 3);
      setPrediction({
        surplusQty:  surplusQty.toFixed(1),
        surplusPct:  (pct * 100).toFixed(0),
        confidence:  Math.floor(55 + Math.random() * 30),
        estValue:    value.toFixed(2),
        valueLow:    (value * 0.5).toFixed(2),
        valueHigh:   (value * 1.8).toFixed(2),
      });
      setLoading(false);
      toast("ML prediction complete — see results below.");
    }, 1800);
  };

  const save = () => {
    setSaved(true);
    toast("Inventory saved. Create a lot when you're ready.");
  };

  const f = (k) => (v) => setForm(prev => ({ ...prev, [k]: v }));

  return (
    <div style={{ padding: 28, maxWidth: 640, margin: "0 auto" }}>
      <button onClick={() => navigate("supplier-dash")} style={{ background: "none", border: "none", color: "#0F4C2A", cursor: "pointer", fontWeight: 600, fontSize: 14, marginBottom: 16 }}>
        ← Back
      </button>
      <h1 style={{ fontSize: 22, fontWeight: 800, color: "#0F4C2A", marginBottom: 6 }}>Add today's inventory</h1>
      <p style={{ color: "#9CA3AF", fontSize: 14, marginBottom: 24 }}>Enter what you have on hand. Our ML model predicts your surplus before you list.</p>

      <Card>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}>
          <div style={{ gridColumn: "1 / -1" }}>
            <Input label="Item name" value={form.name} onChange={f("name")} placeholder="e.g. Sourdough loaves" required />
          </div>
          <Select label="Category" value={form.category} onChange={f("category")}
            options={["bakery","produce","dairy","prepared","meat","dry","beverage"].map(c => ({ value: c, label: c.charAt(0).toUpperCase() + c.slice(1) }))}
          />
          <Select label="Temperature" value={form.temperature} onChange={f("temperature")}
            options={[["ambient","Ambient 🌡️"],["chilled","Chilled ❄️"],["frozen","Frozen 🧊"],["hot","Hot 🔥"]].map(([v,l]) => ({ value: v, label: l }))}
          />
          <Input label="Total quantity" type="number" value={form.quantity} onChange={f("quantity")} placeholder="0" />
          <Select label="Unit" value={form.unit} onChange={f("unit")}
            options={["kg","units","liters","packs"].map(u => ({ value: u, label: u }))}
          />
          <div style={{ gridColumn: "1 / -1" }}>
            <Input label="Best-before / expiry" type="datetime-local" value={form.expiry} onChange={f("expiry")} />
          </div>
          <Input label="Pickup from" type="datetime-local" value={form.pickupStart} onChange={f("pickupStart")} />
          <Input label="Pickup until" type="datetime-local" value={form.pickupEnd}   onChange={f("pickupEnd")} />
        </div>

        <div style={{ display: "flex", gap: 10, marginTop: 8 }}>
          <Btn onClick={predict} disabled={loading} variant="ghost" style={{ flex: 1 }}>
            {loading ? "Running ML model…" : "Get surplus prediction"}
          </Btn>
          <Btn onClick={save} disabled={saved} style={{ flex: 1 }}>
            {saved ? "Saved ✓" : "Save inventory"}
          </Btn>
        </div>
      </Card>

      {/* ML Prediction result */}
      {prediction && (
        <Card style={{ marginTop: 16, border: "2px solid #86EFAC", background: "#F0FDF4" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
