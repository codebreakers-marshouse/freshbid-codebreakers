                    color: isSnipe ? "#F59E0B" : urgent ? "#EF4444" : "#374151",
                  }}>
                    {expired ? "Closed" : fmtCountdown(msLeft)}
                  </p>
                </div>
              </div>

              {lot.buyNow && (
                <p style={{ marginTop: 10, fontSize: 12, color: "#2563EB", fontWeight: 600 }}>
                  Buy now: {fmtCurrency(lot.buyNow)}
                </p>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}

