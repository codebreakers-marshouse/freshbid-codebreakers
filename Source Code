function MyWins({ toast }) {
  const [wins, setWins] = useState(MY_WINS);
  const [codes, setCodes] = useState({});

  const confirm = (id, code) => {
    const win = wins.find(w => w.id === id);
    if (code !== win.confirmationCode) { toast("Wrong code. Try again.", "error"); return; }
    setWins(prev => prev.map(w => w.id === id ? { ...w, pickupStatus: "completed" } : w));
    toast("Pickup confirmed! Donation receipt sent to your email.");
  };

  const totalDonated = wins.reduce((s, w) => s + w.donationAmount, 0);
  const completed    = wins.filter(w => w.pickupStatus === "completed").length;

  return (
    <div style={{ padding: 28, maxWidth: 720, margin: "0 auto" }}>
      <h1 style={{ fontSize: 24, fontWeight: 800, color: "#0F4C2A", marginBottom: 6 }}>My Wins</h1>

      {/* Impact row */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 12, marginBottom: 24 }}>
        <KpiCard label="Auctions won"     value={wins.length}        accent="#0F4C2A" />
        <KpiCard label="Pickups done"     value={completed}          accent="#2563EB" />
        <KpiCard label="Total donated"    value={fmtCurrency(totalDonated)} accent="#7C3AED" />
      </div>

      <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
        {wins.map(win => {
          const done = win.pickupStatus === "completed";
          const msLeft = win.pickupEnd - Date.now();
          return (
            <Card key={win.id} style={{ borderLeft: `4px solid ${done ? "#10B981" : "#F59E0B"}` }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 12 }}>
                <div>
                  <p style={{ fontSize: 16, fontWeight: 700, margin: "0 0 3px" }}>{win.title}</p>
                  <p style={{ fontSize: 13, color: "#9CA3AF", margin: 0 }}>{win.supplier}</p>
                </div>
                <Badge
                  color={done ? "#065F46" : "#92400E"}
                  bg={done ? "#D1FAE5" : "#FEF3C7"}
                >
                  {done ? "✅ Complete" : "⏳ Pending pickup"}
                </Badge>
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8, fontSize: 13, color: "#6B7280", marginBottom: 14 }}>
                <p style={{ margin: 0 }}>📍 {win.address}</p>
                <p style={{ margin: 0 }}>💰 Paid: {fmtCurrency(win.paymentAmount)}</p>
                <p style={{ margin: 0, color: "#059669" }}>🤝 {fmtCurrency(win.donationAmount)} → {win.charityName}</p>
                {!done && <p style={{ margin: 0, color: msLeft < 0 ? "#EF4444" : "#374151" }}>
                  🕐 {msLeft < 0 ? "Window passed" : `${fmtCountdown(msLeft)} left to collect`}
                </p>}
              </div>

              {!done && (
                <div style={{ borderTop: "1px solid #F3F4F6", paddingTop: 14 }}>
                  <p style={{ fontSize: 12, color: "#9CA3AF", marginBottom: 8 }}>
                    Enter the 4-digit code the supplier gives you when you collect
                  </p>
                  <div style={{ display: "flex", gap: 8 }}>
                    <input
                      type="text" maxLength={4} placeholder="0000"
                      value={codes[win.id] || ""}
                      onChange={e => setCodes(prev => ({ ...prev, [win.id]: e.target.value.replace(/\D/g, "") }))}
                      style={{
                        width: 80, padding: "8px 12px", borderRadius: 8,
                        border: "1.5px solid #D1D5DB", fontSize: 20, fontWeight: 700,
                        textAlign: "center", fontFamily: "monospace", outline: "none",
                      }}
                    />
                    <Btn
                      onClick={() => confirm(win.id, codes[win.id])}
                      disabled={(codes[win.id] || "").length !== 4}
                    >
                      Confirm pickup
                    </Btn>
                  </div>
                  <p style={{ fontSize: 11, color: "#9CA3AF", marginTop: 8 }}>
                    💡 Demo: code is <strong>{win.confirmationCode}</strong>
                  </p>
                </div>
              )}
            </Card>
          );
        })}
      </div>
    </div>
  );
}

