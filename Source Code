function Toast({ toasts }) {
  return (
    <div style={{ position: "fixed", top: 20, right: 20, zIndex: 9999, display: "flex", flexDirection: "column", gap: 8 }}>
      {toasts.map(t => (
        <div key={t.id} style={{
          background: t.type === "error" ? "#EF4444" : t.type === "warn" ? "#F59E0B" : "#10B981",
          color: "#fff", padding: "10px 16px", borderRadius: 8,
          boxShadow: "0 4px 12px rgba(0,0,0,0.15)", fontSize: 14, fontWeight: 500,
          maxWidth: 340, animation: "slideIn 0.2s ease",
        }}>
          {t.msg}
        </div>
      ))}
    </div>
  );
}

function Badge({ children, color = "#166534", bg = "#DCFCE7" }) {
  return (
    <span style={{
      display: "inline-block", padding: "2px 10px", borderRadius: 99,
      fontSize: 12, fontWeight: 600, color, background: bg,
    }}>
      {children}
    </span>
  );
}

function Btn({ children, onClick, disabled, variant = "primary", style = {} }) {
  const styles = {
    primary: { background: "#0F4C2A", color: "#fff" },
    secondary: { background: "#fff", color: "#374151", border: "1px solid #D1D5DB" },
    danger: { background: "#EF4444", color: "#fff" },
    ghost: { background: "transparent", color: "#0F4C2A", border: "1px solid #0F4C2A" },
  };
  return (
    <button
      onClick={onClick}
      disabled={disabled}
      style={{
        padding: "8px 18px", borderRadius: 8, border: "none",
        fontWeight: 600, fontSize: 14, cursor: disabled ? "not-allowed" : "pointer",
        opacity: disabled ? 0.45 : 1, transition: "opacity 0.15s",
        ...styles[variant], ...style,
      }}
    >
      {children}
    </button>
  );
}

function Input({ label, type = "text", value, onChange, placeholder, min, step, required, note }) {
  return (
    <div style={{ marginBottom: 16 }}>
      {label && (
        <label style={{ display: "block", fontSize: 13, fontWeight: 600, color: "#374151", marginBottom: 4 }}>
          {label}{required && <span style={{ color: "#EF4444" }}> *</span>}
        </label>
      )}
      <input
        type={type} value={value} onChange={e => onChange(e.target.value)}
        placeholder={placeholder} min={min} step={step}
        style={{
          width: "100%", padding: "8px 12px", borderRadius: 8,
          border: "1.5px solid #D1D5DB", fontSize: 14, outline: "none",
          boxSizing: "border-box", background: "#fff", transition: "border-color 0.15s",
        }}
        onFocus={e => e.target.style.borderColor = "#0F4C2A"}
        onBlur={e => e.target.style.borderColor = "#D1D5DB"}
      />
      {note && <p style={{ fontSize: 12, color: "#9CA3AF", marginTop: 4 }}>{note}</p>}
    </div>
  );
}

function Select({ label, value, onChange, options }) {
  return (
    <div style={{ marginBottom: 16 }}>
      {label && <label style={{ display: "block", fontSize: 13, fontWeight: 600, color: "#374151", marginBottom: 4 }}>{label}</label>}
      <select
        value={value} onChange={e => onChange(e.target.value)}
        style={{ width: "100%", padding: "8px 12px", borderRadius: 8, border: "1.5px solid #D1D5DB", fontSize: 14, background: "#fff", outline: "none" }}
      >
        {options.map(o => <option key={o.value} value={o.value}>{o.label}</option>)}
      </select>
    </div>
  );
}

function Card({ children, style = {} }) {
  return (
    <div style={{
      background: "#fff", borderRadius: 12, border: "1px solid #E5E7EB",
      padding: 20, ...style,
    }}>
      {children}
    </div>
  );
}

