function CreateLot({ navigate, toast }) {
  const [form, setForm] = useState({
    title: "", description: "", categories: ["bakery"],
    quantity: "", unit: "kg", temperature: "ambient",
    reserve: "", buyNow: "", increment: "1",
    auctionStart: "", auctionEnd: "",
    pickupStart: "", pickupEnd: "", expiry: "",
  });
  const [saving, setSaving] = useState(false);
  const f = (k) => (v) => setForm(prev => ({ ...prev, [k]: v }));

  const submit = () => {
    if (!form.title || !form.quantity || !form.reserve) {
      toast("Fill in title, quantity, and reserve price.", "error"); return;
    }
    setSaving(true);
    setTimeout(() => {
      setSaving(false);
      toast("Lot created and live! ML suggested reserve confirmed.");
      navigate("supplier-dash");
    }, 1200);
  };

  return (
    <div style={{ padding: 28, maxWidth: 640, margin: "0 auto" }}>
      <button onClick={() => navigate("supplier-dash")} style={{ background: "none", border: "none", color: "#0F4C2A", cursor: "pointer", fontWeight: 600, fontSize: 14, marginBottom: 16 }}>
        ← Back
      </button>
      <h1 style={{ fontSize: 22, fontWeight: 800, color: "#0F4C2A", marginBottom: 6 }}>Create auction lot</h1>
      <p style={{ color: "#9CA3AF", fontSize: 14, marginBottom: 24 }}>Set your terms. ML price guidance updates on submit.</p>

      <Card>
        <div style={{ gridColumn: "1 / -1" }}>
          <Input label="Lot title" value={form.title} onChange={f("title")} placeholder="e.g. Mixed Bakery Surplus – Day-old sourdough & pastries" required />
        </div>

        <div style={{ marginBottom: 16 }}>
          <label style={{ display: "block", fontSize: 13, fontWeight: 600, color: "#374151", marginBottom: 6 }}>Description</label>
          <textarea
            value={form.description} onChange={e => setForm(prev => ({ ...prev, description: e.target.value }))}
            placeholder="Buyer-facing description. Include quality notes and what's in the lot."
            rows={3} style={{ width: "100%", padding: "8px 12px", borderRadius: 8, border: "1.5px solid #D1D5DB", fontSize: 14, resize: "vertical", outline: "none", boxSizing: "border-box" }}
          />
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "2fr 1fr", gap: 12 }}>
          <Input label="Quantity" type="number" value={form.quantity} onChange={f("quantity")} placeholder="50" required />
          <Select label="Unit" value={form.unit} onChange={f("unit")}
            options={["kg","units","liters","packs"].map(u => ({ value: u, label: u }))}
          />
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
          <Select label="Temperature" value={form.temperature} onChange={f("temperature")}
            options={[["ambient","🌡️ Ambient"],["chilled","❄️ Chilled"],["frozen","🧊 Frozen"],["hot","🔥 Hot"]].map(([v,l]) => ({ value: v, label: l }))}
          />
          <Input label="Min bid increment ($)" type="number" value={form.increment} onChange={f("increment")} step="0.5" />
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
          <Input label="Reserve price ($)" type="number" value={form.reserve} onChange={f("reserve")} placeholder="20.00" required />
          <Input label="Buy-now price ($)" type="number" value={form.buyNow} onChange={f("buyNow")} placeholder="optional" />
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
          <Input label="Auction start" type="datetime-local" value={form.auctionStart} onChange={f("auctionStart")} />
          <Input label="Auction end"   type="datetime-local" value={form.auctionEnd}   onChange={f("auctionEnd")} />
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
          <Input label="Pickup from" type="datetime-local" value={form.pickupStart} onChange={f("pickupStart")} />
          <Input label="Pickup until" type="datetime-local" value={form.pickupEnd} onChange={f("pickupEnd")} />
        </div>

        <div style={{ background: "#F0FDF4", border: "1px solid #86EFAC", borderRadius: 8, padding: 12, marginBottom: 16, fontSize: 13, color: "#065F46" }}>
          💡 After you create this lot, ML will suggest a predicted clearing price based on zone history, urgency, and buyer demand. Your reserve is protected regardless.
        </div>

        <Btn onClick={submit} disabled={saving} style={{ width: "100%", padding: 12, fontSize: 16 }}>
          {saving ? "Creating lot…" : "Create lot & go live"}
        </Btn>
      </Card>
    </div>
  );
}

